<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<?import javafx.scene.control.Tooltip?>
<AnchorPane prefHeight="700.0" prefWidth="1014.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.gem_management_layered.controller.StockController">

    <!-- HEADER -->
    <VBox alignment="CENTER" prefHeight="50.0" prefWidth="1014.0" style="-fx-background-color: #8e061b;">
        <children>
            <Text fill="WHITESMOKE" text="STOCK">
                <font>
                    <Font name="System Bold" size="35" />
                </font>
            </Text>
        </children>
    </VBox>

    <!-- FORM PANE -->
    <Pane layoutY="50.0" prefHeight="280.0" prefWidth="1014.0" style="-fx-background-color: #000000;">
        <children>

            <!-- BACKGROUND IMAGES -->
            <ImageView fitHeight="260" fitWidth="470" layoutX="20" opacity="0.15">
                <image>
                    <Image url="@GemImages/WhatsApp%20Image%202025-12-23%20at%2000.51.10.jpeg" />
                </image>
            </ImageView>

            <ImageView fitHeight="260" fitWidth="440" layoutX="560.0" opacity="0.12">
                <image>
                    <Image url="@GemImages/WhatsApp%20Image%202025-12-23%20at%2000.51.10.jpeg" />
                </image>
            </ImageView>


            <!-- Input Fields -->

            <!-- STOCK ID -->
            <VBox layoutX="30" layoutY="20" spacing="5"><Label text="Stock ID :" textFill="WHITESMOKE"><font><Font name="System Bold" size="16" /></font></Label><TextField fx:id="txtStockId"   prefHeight="25.0" prefWidth="300.0" />
            </VBox>


            <!-- GEM SELECTION -->
            <VBox layoutX="30.0" layoutY="158.0" spacing="5"><Label text="Select Gem :" textFill="WHITESMOKE"><font><Font name="System Bold" size="16"
            /></font></Label><ComboBox fx:id="cmbGem" prefHeight="25.0" prefWidth="300.0" />
            </VBox>

            <!-- QUANTITY -->
            <VBox layoutX="566.0" layoutY="20.0" spacing="5">
                <Label text="Quantity :" textFill="WHITESMOKE"><font><Font name="System Bold" size="16" />
                </font></Label><TextField fx:id="txtQuantity" prefHeight="25.0" prefWidth="300.0" />
            </VBox>

            <!-- DATE -->
            <VBox layoutX="566.0" layoutY="90.0" spacing="5">
                <Label text="Date :" textFill="WHITESMOKE"><font><Font name="System Bold" size="16" /></font></Label><DatePicker fx:id="dpDate" prefHeight="25.0" prefWidth="300.0" />
            </VBox>




            <!-- BUTTONS -->
            <HBox alignment="CENTER" layoutX="346.0" layoutY="224.0" spacing="10">
                <children>

<!--                    &lt;!&ndash; Stock Report Button &ndash;&gt;-->
<!--                    <Button onAction="#stockReport" prefHeight="36.0" prefWidth="111.0"-->
<!--                            style="-fx-background-color:#6A1B9A; -fx-text-fill: white;-fx-font-weight: bold;" text="Stock Report">-->
<!--                        <tooltip>-->
<!--                            <Tooltip text="Generate Stock Report"-->
<!--                                     style="-->
<!--                             -fx-background-color: linear-gradient(to bottom, #7B1FA2, #4A148C);-->
<!--                             -fx-text-fill: white;-->
<!--                             -fx-font-size: 12px;-->
<!--                             -fx-font-weight: bold;-->
<!--                             -fx-padding: 6 10;-->
<!--                             -fx-background-radius: 6;-->
<!--                             -fx-border-radius: 6;-->
<!--                             -fx-border-color: #4A148C;-->
<!--                             -fx-border-width: 1.5;-->
<!--                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 8, 0, 0, 2);-->
<!--                         "/>-->
<!--                        </tooltip>-->
<!--                    </Button>-->

                    <!-- Save Button -->
                    <Button onAction="#saveStock" prefHeight="36.0" prefWidth="111.0"
                            style="-fx-background-color:#2E7D32; -fx-text-fill: white;-fx-font-weight: bold;" text="Save">
                        <tooltip>
                            <Tooltip text="Save Stock Details"
                                     style="
                             -fx-background-color: linear-gradient(to bottom, #43A047, #1B5E20);
                             -fx-text-fill: white;
                             -fx-font-size: 12px;
                             -fx-font-weight: bold;
                             -fx-padding: 6 10;
                             -fx-background-radius: 6;
                             -fx-border-radius: 6;
                             -fx-border-color: #1B5E20;
                             -fx-border-width: 1.5;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 8, 0, 0, 2);
                         "/>
                        </tooltip>
                    </Button>

                    <!-- Update Button -->
                    <Button onAction="#updateStock" prefHeight="36.0" prefWidth="111.0"
                            style="-fx-background-color:#1976D2; -fx-text-fill: white;-fx-font-weight: bold;" text="Update">
                        <tooltip>
                            <Tooltip text="Update Stock Details"
                                     style="
                             -fx-background-color: linear-gradient(to bottom, #2196F3, #0D47A1);
                             -fx-text-fill: white;
                             -fx-font-size: 12px;
                             -fx-font-weight: bold;
                             -fx-padding: 6 10;
                             -fx-background-radius: 6;
                             -fx-border-radius: 6;
                             -fx-border-color: #0D47A1;
                             -fx-border-width: 1.5;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 8, 0, 0, 2);
                         "/>
                        </tooltip>
                    </Button>

                    <!-- Delete Button -->
                    <Button onAction="#deleteStock" prefHeight="36.0" prefWidth="111.0"
                            style="-fx-background-color:#8e061b; -fx-text-fill: white; -fx-font-weight: bold;" text="Delete">
                        <tooltip>
                            <Tooltip text="Delete Stock Record"
                                     style="
                             -fx-background-color: linear-gradient(to bottom, #B71C1C, #7F0000);
                             -fx-text-fill: white;
                             -fx-font-size: 12px;
                             -fx-font-weight: bold;
                             -fx-padding: 6 10;
                             -fx-background-radius: 6;
                             -fx-border-radius: 6;
                             -fx-border-color: #7F0000;
                             -fx-border-width: 1.5;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 8, 0, 0, 2);
                         "/>
                        </tooltip>
                    </Button>

                    <!-- Reset Button -->
                    <Button onAction="#resetStock" prefHeight="36.0" prefWidth="111.0"
                            style="-fx-background-color: orange; -fx-text-fill: white;-fx-font-weight: bold;" text="Reset">
                        <tooltip>
                            <Tooltip text="Reset All Fields"
                                     style="
                             -fx-background-color: linear-gradient(to bottom, #FFA726, #F57C00);
                             -fx-text-fill: white;
                             -fx-font-size: 12px;
                             -fx-font-weight: bold;
                             -fx-padding: 6 10;
                             -fx-background-radius: 6;
                             -fx-border-radius: 6;
                             -fx-border-color: #F57C00;
                             -fx-border-width: 1.5;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 8, 0, 0, 2);
                         "/>
                        </tooltip>
                    </Button>



                </children>
            </HBox>


            <!-- STOCK ID -->
            <VBox layoutX="30.0" layoutY="90.0" spacing="5">
                <Label text="Gem ID :" textFill="WHITESMOKE">
                    <font>
                        <Font name="System Bold" size="16" />
                    </font>
                </Label>
                <TextField fx:id="txtGemId" prefHeight="25.0" prefWidth="300.0" />
            </VBox>

        </children>
    </Pane>

    <!-- TABLE PANE -->
    <Pane layoutY="330" prefHeight="370" prefWidth="1014.0" style="-fx-background-color:#000000;">
        <children>

            <ImageView fitHeight="367.0" fitWidth="654.0" layoutX="351.0" opacity="0.15" pickOnBounds="true" preserveRatio="true">
                <image>
                    <Image url="@GemImages/1182460-3840x2160-desktop-4k-gemstone-background-photo.jpg" />
                </image>
            </ImageView>

            <TableView fx:id="tableStock" opacity="0.49" prefHeight="370.0" prefWidth="1014.0">
                <columns>

                    <TableColumn fx:id="colStockId" minWidth="0.0" prefWidth="201.0" text="Stock ID" />

                    <TableColumn fx:id="colGemId" prefWidth="150.0" text="Gem ID" />
                    <TableColumn fx:id="colGemName" prefWidth="249.0" text="Gem Name" />
                    <TableColumn fx:id="colQuantity" minWidth="0.0" prefWidth="166.0" text="Quantity" />
                    <TableColumn fx:id="colDate" prefWidth="384.0" text="Date" />
                </columns>
            </TableView>
        </children>
    </Pane>

</AnchorPane>
