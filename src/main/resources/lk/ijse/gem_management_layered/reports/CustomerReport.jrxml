<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!DOCTYPE jasperReport PUBLIC
        "-//JasperReports//DTD Report Design//EN"
        "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">

<jasperReport name="CustomerReport"
              pageWidth="595"
              pageHeight="842"
              columnWidth="555"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20">

    <!-- SQL Query must come BEFORE fields -->
    <queryString language="SQL">
        <![CDATA[
            SELECT id, first_name, last_name, contact
            FROM customers
        ]]>
    </queryString>

    <!-- Fields -->
    <field name="id" class="java.lang.Integer"/>
    <field name="first_name" class="java.lang.String"/>
    <field name="last_name" class="java.lang.String"/>
    <field name="contact" class="java.lang.String"/>

    <!-- Title -->
    <title>
        <band height="50">
            <staticText>
                <reportElement x="0" y="10" width="555" height="30"/>
                <textElement textAlignment="Center">
                    <font size="18" isBold="true"/>
                </textElement>
                <text><![CDATA[Customer List Report]]></text>
            </staticText>
        </band>
    </title>

    <!-- Column Header -->
    <columnHeader>
        <band height="25">
            <staticText><reportElement x="0" y="0" width="80" height="20"/><text><![CDATA[ID]]></text></staticText>
            <staticText><reportElement x="80" y="0" width="150" height="20"/><text><![CDATA[First Name]]></text></staticText>
            <staticText><reportElement x="230" y="0" width="120" height="20"/><text><![CDATA[Last Name]]></text></staticText>
            <staticText><reportElement x="350" y="0" width="205" height="20"/><text><![CDATA[Contact]]></text></staticText>
        </band>
    </columnHeader>

    <!-- Detail -->
    <detail>
        <band height="20">
            <textField><reportElement x="0" y="0" width="80" height="20"/><textFieldExpression><![CDATA[$F{id}]]></textFieldExpression></textField>
            <textField><reportElement x="80" y="0" width="150" height="20"/><textFieldExpression><![CDATA[$F{first_name}]]></textFieldExpression></textField>
            <textField><reportElement x="230" y="0" width="120" height="20"/><textFieldExpression><![CDATA[$F{last_name}]]></textFieldExpression></textField>
            <textField><reportElement x="350" y="0" width="205" height="20"/><textFieldExpression><![CDATA[$F{contact}]]></textFieldExpression></textField>
        </band>
    </detail>

</jasperReport>
