<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="700.0" prefWidth="1014.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lk.ijse.gem_management_layered.controller.UserController">

    <!-- Header -->
    <VBox alignment="CENTER" prefHeight="50" prefWidth="1014"
          style="-fx-background-color:#8e061b;">
        <children>
            <Text fill="WHITESMOKE" text="USERS">
                <font>
                    <Font name="System Bold" size="35"/>
                </font>
            </Text>
        </children>
    </VBox>

    <!-- Input Form Pane -->
    <Pane layoutY="50" prefHeight="286" prefWidth="1014"
          style="-fx-background-color:#000000;">
        <children>

            <!-- Background Images -->
            <ImageView fitHeight="286" fitWidth="470" layoutX="14"
                       opacity="0.2" preserveRatio="true">
                <image>
                    <Image url="@GemImages/WhatsApp%20Image%202025-12-23%20at%2000.51.10.jpeg"/>
                </image>
            </ImageView>

            <ImageView fitHeight="275" fitWidth="444"
                       layoutX="566" layoutY="6"
                       opacity="0.17" preserveRatio="true">
                <image>
                    <Image url="@GemImages/WhatsApp%20Image%202025-12-23%20at%2000.51.10.jpeg"/>
                </image>
            </ImageView>

            <!-- Input Fields -->
            <VBox layoutX="26" layoutY="14" spacing="5">
                <Label text="User ID:" textFill="WHITESMOKE">
                    <font><Font size="16"/></font>
                </Label>
                <TextField fx:id="txtUserId" onKeyPressed="#searchUser"
                           prefWidth="300"/>
            </VBox>

            <VBox layoutX="26" layoutY="75" spacing="5">
                <Label text="Username:" textFill="WHITESMOKE">
                    <font><Font size="16"/></font>
                </Label>
                <TextField fx:id="txtUsername" prefWidth="300"/>
            </VBox>

            <VBox layoutX="26" layoutY="137" spacing="5">
                <Label text="Password:" textFill="WHITESMOKE">
                    <font><Font size="16"/></font>
                </Label>
                <PasswordField fx:id="txtPassword" prefWidth="300"/>
            </VBox>

            <VBox layoutX="507" layoutY="14" spacing="5">
                <Label text="Role:" textFill="WHITESMOKE">
                    <font><Font size="16"/></font>
                </Label>
                <ComboBox fx:id="cmbRole" prefWidth="224"/>
            </VBox>

            <!-- Buttons -->
            <HBox alignment="CENTER"
                  layoutX="382" layoutY="182"
                  prefHeight="55" prefWidth="614"
                  spacing="10">

                <!-- Save Button -->
                <Button text="Save"
                        prefWidth="111"
                        prefHeight="36.0"
                        style="-fx-background-color:#2E7D32; -fx-font-weight: bold;"
                        textFill="WHITESMOKE"
                        onAction="#saveUser">
                    <tooltip>
                        <Tooltip text="Save User Details"
                                 style="
                         -fx-background-color: linear-gradient(to bottom, #43A047, #1B5E20);
                         -fx-text-fill: white;
                         -fx-font-size: 12px;
                         -fx-font-weight: bold;
                         -fx-padding: 6 10;
                         -fx-background-radius: 6;
                         -fx-border-radius: 6;
                         -fx-border-color: #1B5E20;
                         -fx-border-width: 1.5;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 8, 0, 0, 2);
                     "/>
                    </tooltip>
                </Button>

                <!-- Update Button -->
                <Button text="Update"
                        prefHeight="36.0"
                        prefWidth="111"
                        style="-fx-background-color:#1976D2; -fx-font-weight: bold;"
                        textFill="WHITESMOKE"
                        onAction="#updateUser">
                    <tooltip>
                        <Tooltip text="Update User Details"
                                 style="
                         -fx-background-color: linear-gradient(to bottom, #2196F3, #0D47A1);
                         -fx-text-fill: white;
                         -fx-font-size: 12px;
                         -fx-font-weight: bold;
                         -fx-padding: 6 10;
                         -fx-background-radius: 6;
                         -fx-border-radius: 6;
                         -fx-border-color: #0D47A1;
                         -fx-border-width: 1.5;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 8, 0, 0, 2);
                     "/>
                    </tooltip>
                </Button>

                <!-- Delete Button -->
                <Button text="Delete"
                        prefHeight="36.0"
                        prefWidth="111"
                        style="-fx-background-color:#8e061b; -fx-font-weight: bold;"
                        textFill="WHITESMOKE"
                        onAction="#deleteUser">
                    <tooltip>
                        <Tooltip text="Delete User Record"
                                 style="
                         -fx-background-color: linear-gradient(to bottom, #B71C1C, #7F0000);
                         -fx-text-fill: white;
                         -fx-font-size: 12px;
                         -fx-font-weight: bold;
                         -fx-padding: 6 10;
                         -fx-background-radius: 6;
                         -fx-border-radius: 6;
                         -fx-border-color: #7F0000;
                         -fx-border-width: 1.5;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 8, 0, 0, 2);
                     "/>
                    </tooltip>
                </Button>

                <!-- Reset Button -->
                <Button text="Reset"
                        prefHeight="36.0"
                        prefWidth="111"
                        style="-fx-background-color:orange; -fx-font-weight: bold;"
                        textFill="WHITESMOKE"
                        onAction="#resetUser">
                    <tooltip>
                        <Tooltip text="Reset All Fields"
                                 style="

                         -fx-background-color: linear-gradient(to bottom, #FFA726, #F57C00);
                         -fx-text-fill: white;
                         -fx-font-size: 12px;
                         -fx-font-weight: bold;
                         -fx-padding: 6 10;
                         -fx-background-radius: 6;
                         -fx-border-radius: 6;
                         -fx-border-color: #F57C00;
                         -fx-border-width: 1.5;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 8, 0, 0, 2);
                     "/>
                    </tooltip>
                </Button>

            </HBox>

        </children>
    </Pane>

    <!-- TableView -->
    <Pane layoutY="335" prefHeight="367" prefWidth="1014"
          style="-fx-background-color:#000000;">
        <children>

            <ImageView fitHeight="367" fitWidth="654"
                       layoutX="351"
                       opacity="0.15"
                       preserveRatio="true">
                <image>
                    <Image url="@GemImages/1182460-3840x2160-desktop-4k-gemstone-background-photo.jpg"/>
                </image>
            </ImageView>

            <TableView fx:id="tableUser"
                       opacity="0.49"
                       prefHeight="367"
                       prefWidth="1014">
                <columns>
                    <TableColumn fx:id="colUserId"
                                 prefWidth="300"
                                 text="User ID"/>
                    <TableColumn fx:id="colUsername"
                                 prefWidth="350"
                                 text="Username"/>
                    <TableColumn fx:id="colRole"
                                 prefWidth="350"
                                 text="Role"/>
                </columns>
            </TableView>

        </children>
    </Pane>

</AnchorPane>
