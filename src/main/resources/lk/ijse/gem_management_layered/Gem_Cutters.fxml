

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<?import javafx.scene.control.Tooltip?>
<AnchorPane prefHeight="700" prefWidth="1015" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.gem_management_layered.controller.Gem_CutterController">

    <!-- Header -->
    <VBox alignment="CENTER" prefHeight="50" prefWidth="1015" style="-fx-background-color: #8e061b;">
        <children>
            <Text fill="WHITESMOKE" text="GEM CUTTER">
                <font>
                    <Font name="System Bold" size="34" />
                </font>
            </Text>
        </children>
    </VBox>

    <!-- Input Pane -->
    <Pane layoutY="50" prefHeight="280" prefWidth="1015" style="-fx-background-color: #000000;">
        <children>

            <!-- Background Images -->
            <ImageView fitHeight="286.0" fitWidth="470.0" layoutX="14.0" opacity="0.2" pickOnBounds="true" preserveRatio="true">
                <image>
                    <Image url="@GemImages/WhatsApp%20Image%202025-12-23%20at%2000.51.10.jpeg" />
                </image>
            </ImageView>
            <ImageView fitHeight="275.0" fitWidth="444.0" layoutX="566.0" layoutY="6.0" opacity="0.17" pickOnBounds="true" preserveRatio="true">
                <image>
                    <Image url="@GemImages/WhatsApp%20Image%202025-12-23%20at%2000.51.10.jpeg" />
                </image>
            </ImageView>



            <!-- Cutter ID -->
            <VBox layoutX="47" layoutY="20" prefHeight="45" prefWidth="295">
                <Label text="Cutter_ID :" textFill="WHITESMOKE">
                    <font><Font name="System Bold" size="16" /></font>
                </Label>
                <TextField fx:id="cutterid"  onKeyPressed="#searchCutter"/>
            </VBox>

            <!-- Name -->
            <VBox layoutX="47" layoutY="80" prefHeight="45" prefWidth="295">
                <Label text="Name :" textFill="WHITESMOKE">
                    <font><Font name="System Bold" size="16" /></font>
                </Label>
                <TextField fx:id="name" />
            </VBox>

            <!-- Contact -->
            <VBox layoutX="47" layoutY="140" prefHeight="45" prefWidth="295">
                <Label text="Contact :" textFill="WHITESMOKE">
                    <font><Font name="System Bold" size="16" /></font>
                </Label>
                <TextField fx:id="contact" />
            </VBox>

            <!-- Address -->
            <VBox layoutX="492" layoutY="20" prefHeight="100" prefWidth="295">
                <Label text="Address :" textFill="WHITESMOKE">
                    <font><Font name="System Bold" size="16" /></font>
                </Label>
                <TextArea fx:id="address" prefHeight="70" />
            </VBox>

            <!-- Buttons -->
            <HBox layoutX="382" layoutY="182" prefHeight="55.0" prefWidth="614.0" spacing="12">
                <children>

                    <!-- Save Button -->
                    <Button onAction="#saveCutter" prefHeight="36.0" prefWidth="111.0"
                            style="-fx-background-color: #2E7D32;-fx-font-weight: bold; -fx-text-fill: white;" text="Save">
                        <tooltip>
                            <Tooltip text="Save Gem Cutter Details"
                                     style="
                             -fx-background-color: linear-gradient(to bottom, #43A047, #1B5E20);
                             -fx-text-fill: white;
                             -fx-font-size: 12px;
                             -fx-font-weight: bold;
                             -fx-padding: 6 10;
                             -fx-background-radius: 6;
                             -fx-border-radius: 6;
                             -fx-border-color: #1B5E20;
                             -fx-border-width: 1.5;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 8, 0, 0, 2);
                         "/>
                        </tooltip>
                    </Button>

                    <!-- Update Button -->
                    <Button onAction="#updateCutter" prefHeight="36.0" prefWidth="111.0"
                            style="-fx-background-color: #1976D2;-fx-font-weight: bold; -fx-text-fill: white;" text="Update">
                        <tooltip>
                            <Tooltip text="Update Gem Cutter Details"
                                     style="
                             -fx-background-color: linear-gradient(to bottom, #2196F3, #0D47A1);
                             -fx-text-fill: white;
                             -fx-font-size: 12px;
                             -fx-font-weight: bold;
                             -fx-padding: 6 10;
                             -fx-background-radius: 6;
                             -fx-border-radius: 6;
                             -fx-border-color: #0D47A1;
                             -fx-border-width: 1.5;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 8, 0, 0, 2);
                         "/>
                        </tooltip>
                    </Button>

                    <!-- Delete Button -->
                    <Button onAction="#deleteCutter" prefHeight="36.0" prefWidth="111.0"
                            style="-fx-background-color: #8e061b; -fx-font-weight: bold; -fx-text-fill: white;" text="Delete">
                        <tooltip>
                            <Tooltip text="Delete Gem Cutter Record"
                                     style="
                             -fx-background-color: linear-gradient(to bottom, #B71C1C, #7F0000);
                             -fx-text-fill: white;
                             -fx-font-size: 12px;
                             -fx-font-weight: bold;
                             -fx-padding: 6 10;
                             -fx-background-radius: 6;
                             -fx-border-radius: 6;
                             -fx-border-color: #7F0000;
                             -fx-border-width: 1.5;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 8, 0, 0, 2);
                         "/>
                        </tooltip>
                    </Button>

                    <!-- Reset Button -->
                    <Button onAction="#resetCutter" prefHeight="36.0" prefWidth="111.0"
                            style="-fx-background-color: orange; -fx-font-weight: bold; -fx-text-fill: white;" text="Reset">
                        <tooltip>
                            <Tooltip text="Reset All Fields"
                                     style="
                             -fx-background-color: linear-gradient(to bottom, #FFA726, #F57C00);
                             -fx-text-fill: white;
                             -fx-font-size: 12px;
                             -fx-font-weight: bold;
                             -fx-padding: 6 10;
                             -fx-background-radius: 6;
                             -fx-border-radius: 6;
                             -fx-border-color: #F57C00;
                             -fx-border-width: 1.5;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 8, 0, 0, 2);
                         "/>
                        </tooltip>
                    </Button>

                </children>
            </HBox>

        </children>
    </Pane>

    <!-- Table Pane -->
    <Pane layoutY="330" prefHeight="370" prefWidth="1015" style="-fx-background-color: #000000;">
        <children>

            <ImageView fitHeight="367.0" fitWidth="654.0" layoutX="351.0" opacity="0.15" pickOnBounds="true" preserveRatio="true">
                <image>
                    <Image url="@GemImages/1182460-3840x2160-desktop-4k-gemstone-background-photo.jpg" />
                </image>
            </ImageView>
            <TableView fx:id="tableCutter" layoutX="0" layoutY="0" opacity="0.42" prefHeight="370" prefWidth="1015">
                <columns>
                    <TableColumn fx:id="colcutterid" prefWidth="150" text="Cutter_ID" />
                    <TableColumn fx:id="colname" prefWidth="250" text="Name" />
                    <TableColumn fx:id="coladdress" prefWidth="400" text="Address" />
                    <TableColumn fx:id="colcontact" prefWidth="200" text="Contact" />
                </columns>
            </TableView>
        </children>
    </Pane>
</AnchorPane>

