<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="750" prefWidth="1014" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.gem_management_layered.controller.OrdersController">

    <!-- ================= HEADER ================= -->
    <VBox alignment="CENTER" prefHeight="55" prefWidth="1014" style="-fx-background-color: #8e061b;">
        <Text fill="WHITESMOKE" text="ORDERS MANAGEMENT" wrappingWidth="451.193359375">
            <Font name="System Bold" size="35.0" />
            <font>
                <Font name="System Bold" size="35.0" />
            </font>
        </Text>
    </VBox>

    <!-- ================= ORDER FORM ================= -->
    <Pane layoutY="55" prefHeight="260" prefWidth="1014" style="-fx-background-color: black;">
        <children>

            <!-- Customer -->
            <VBox layoutX="30" layoutY="20">
                <Label text="Customer" textFill="WHITESMOKE">
                    <Font size="15" />
                </Label>
                <ComboBox fx:id="cmbCustomer" prefWidth="180" />
            </VBox>

            <!-- Gem Cutter -->
            <VBox layoutX="250" layoutY="20">
                <Label text="Gem Cutter" textFill="WHITESMOKE">
                    <Font size="15" />
                </Label>
                <ComboBox fx:id="cmbGemCutter" prefWidth="180" />
            </VBox>

            <!-- Order Date -->
            <VBox layoutX="470" layoutY="20">
                <Label text="Order Date" textFill="WHITESMOKE">
                    <Font size="15" />
                </Label>
                <DatePicker fx:id="orderDatePicker" prefWidth="180" />
            </VBox>

            <!-- Order ID -->
            <VBox layoutX="700" layoutY="20">
                <Label text="Order ID" textFill="WHITESMOKE">
                    <Font size="15" />
                </Label>
                <TextField fx:id="orderIdField" prefWidth="150" />
            </VBox>

            <!-- ===== Order Detail Inputs ===== -->
            <!-- Gem Name ComboBox -->
            <VBox layoutX="30" layoutY="120">
                <Label text="Gem Name" textFill="WHITESMOKE" />
                <ComboBox fx:id="cmbGem" prefWidth="150" />
            </VBox>

            <VBox layoutX="220" layoutY="120">
                <Label text="Quantity" textFill="WHITESMOKE" />
                <TextField fx:id="quantityField" prefWidth="150" />
            </VBox>

            <VBox layoutX="410" layoutY="120">
                <Label text="Unit Price" textFill="WHITESMOKE" />
                <TextField fx:id="unitPriceField" prefWidth="150" />
            </VBox>

            <!-- Add / Remove Buttons -->
            <VBox layoutX="654.0" layoutY="100.0" prefHeight="60.0" prefWidth="104.0" spacing="10">
                <Button onAction="#addOrderDetail" prefHeight="25.0" prefWidth="91.0" style="-fx-background-color:#2E7D32; -fx-text-fill:white;" text="Add Detail" />
                <Button onAction="#removeOrderDetail" style="-fx-background-color:#B71C1C; -fx-text-fill:white;" text="Remove Detail" />
            </VBox>

            <!-- Action Buttons -->
            <HBox layoutX="337.0" layoutY="203.0" spacing="20">

                <!-- Save Order -->
                <Button onAction="#saveOrder" prefHeight="36.0" prefWidth="111.0" style="-fx-background-color:#2E7D32; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:14px;" text="Save Order">
                    <tooltip>
                        <Tooltip style="                          -fx-background-color: linear-gradient(to bottom, #43A047, #1B5E20);                          -fx-text-fill: white;                          -fx-font-size: 12px;                          -fx-font-weight: bold;                          -fx-padding: 6 10;                          -fx-background-radius: 6;                          -fx-border-radius: 6;                          -fx-border-color: #1B5E20;                          -fx-border-width: 1.5;                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 8, 0, 0, 2);                      " text="Save the order details" />
                    </tooltip>
                </Button>

                <!-- Update Order -->
                <Button onAction="#updateOrder" prefHeight="36.0" prefWidth="111.0" style="-fx-background-color:#1976D2; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:14px;" text="Update Order">
                    <tooltip>
                        <Tooltip style="                          -fx-background-color: linear-gradient(to bottom, #2196F3, #0D47A1);                          -fx-text-fill: white;                          -fx-font-size: 12px;                          -fx-font-weight: bold;                          -fx-padding: 6 10;                          -fx-background-radius: 6;                          -fx-border-radius: 6;                          -fx-border-color: #0D47A1;                          -fx-border-width: 1.5;                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 8, 0, 0, 2);                      " text="Update selected order" />
                    </tooltip>
                </Button>

                <!-- Generate Report -->
                <Button onAction="#generateReport" prefHeight="36.0" prefWidth="111.0" style="-fx-background-color:#0D47A1; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:14px;" text="Generate Report">
                    <tooltip>
                        <Tooltip style="-fx-background-color: linear-gradient(to bottom, #1E3C72, #0D47A1);                          -fx-text-fill: white;                          -fx-font-size: 12px;                          -fx-font-weight: bold;                          -fx-padding: 6 10;                          -fx-background-radius: 6;                          -fx-border-radius: 6;                          -fx-border-color: #0D47A1;                          -fx-border-width: 1.5;                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 8, 0, 0, 2);                      " text="Generate order report" />
                    </tooltip>
                </Button>

                <!-- Delete Order -->
                <Button onAction="#deleteOrder" prefHeight="36.0" prefWidth="111.0" style="-fx-background-color:#8e061b; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:14px;" text="Delete Order">
                    <tooltip>
                        <Tooltip style="                          -fx-background-color: linear-gradient(to bottom, #B71C1C, #7F0000);                          -fx-text-fill: white;                          -fx-font-size: 12px;                          -fx-font-weight: bold;                          -fx-padding: 6 10;                          -fx-background-radius: 6;                          -fx-border-radius: 6;                          -fx-border-color: #7F0000;                          -fx-border-width: 1.5;                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 8, 0, 0, 2);                      " text="Delete selected order" />
                    </tooltip>
                </Button>

                <!-- Reset -->
                <Button onAction="#resetOrder" prefHeight="36.0" prefWidth="111.0" style="-fx-background-color:orange; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:14px;" text="Reset">
                    <tooltip>
                        <Tooltip style="                          -fx-background-color: linear-gradient(to bottom, #FFA726, #F57C00);                          -fx-text-fill: white;                          -fx-font-size: 12px;                          -fx-font-weight: bold;                          -fx-padding: 6 10;                          -fx-background-radius: 6;                          -fx-border-radius: 6;                          -fx-border-color: #F57C00;                          -fx-border-width: 1.5;                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 8, 0, 0, 2);                      " text="Clear all order fields" />
                    </tooltip>
                </Button>

            </HBox>


        </children>
    </Pane>
    <Pane layoutY="315.0" prefHeight="435.0" prefWidth="1014.0" style="-fx-background-color: #000000;">
        <children>
            <ImageView fitHeight="456.0" fitWidth="773.0" layoutX="240.0" opacity="0.2" pickOnBounds="true" preserveRatio="true">
                <image>
                    <Image url="@GemImages/1182460-3840x2160-desktop-4k-gemstone-background-photo.jpg" />
                </image>
            </ImageView>

            <!-- ================= ORDERS TABLE ================= -->
            <TableView fx:id="tableOrders" opacity="0.42" prefHeight="193.0" prefWidth="1014.0">

                <columns>
                    <TableColumn fx:id="colOrderId" prefWidth="200" text="Order ID" />
                    <TableColumn fx:id="colCustomerName" prefWidth="300" text="Customer Name" />
                    <TableColumn fx:id="colGemCutterName" prefWidth="300" text="Gem Cutter Name" />
                    <TableColumn fx:id="colOrderDate" prefWidth="214" text="Order Date" />
                </columns>

            </TableView>

            <!-- ================= ORDER DETAILS TABLE ================= -->
            <TableView fx:id="tableOrderDetails" layoutY="213.0" opacity="0.42" prefHeight="224.0" prefWidth="1014.0">
                <columns>
                    <TableColumn fx:id="colGemName" prefWidth="330" text="Gem Name" />
                    <TableColumn fx:id="colQuantity" prefWidth="330" text="Quantity" />
                    <TableColumn fx:id="colUnitPrice" prefWidth="354" text="Unit Price" />
                </columns>
            </TableView>
        </children>
    </Pane>

</AnchorPane>
